{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Multi-Step Tool Plan",
  "description": "Ordered MCP tool invocation plan emitted by the model.",
  "type": "object",
  "required": ["steps"],
  "additionalProperties": false,
  "properties": {
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tool", "arguments"],
        "additionalProperties": false,
        "properties": {
          "tool": {
            "type": "string",
            "description": "Exact MCP tool name"
          },
          "arguments": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}